AUTO_RESTART_COOLDOWN=300

# SSL Monitoring
SSL_WARN_DAYS=30
SSL_CRIT_DAYS=7

# Others
DISK_IO_BUSY_PCT=90
MEM_TREND_CYCLES=5
MEM_TREND_DELTA=3.0
TG_RATE_MAX=20
TG_RATE_WINDOW=60
FD_THRESHOLD=80

# Paths
BASE_DIR=/home/opc/pdfwala
