# ============================================================================
# PDFWala V11.0.0 - Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# SECURITY (REQUIRED - CHANGE THESE!)
# ----------------------------------------------------------------------------
SECRET_KEY=generate-a-secure-random-key-here-min-32-chars
SIGNED_URL_SECRET=generate-another-secure-key-here
API_KEY=pdfwala_your_admin_api_key_here

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
APP_PORT=5000
LOG_LEVEL=INFO
FLASK_DEBUG=false
VERSION=11.0.0

# ----------------------------------------------------------------------------
# STORAGE PATHS (Oracle VM)
# ----------------------------------------------------------------------------
BASE_DATA_DIR=/home/opc/pdfwala
UPLOAD_FOLDER=/home/opc/pdfwala/uploads
OUTPUT_FOLDER=/home/opc/pdfwala/outputs
TEMP_FOLDER=/home/opc/pdfwala/temp

# ----------------------------------------------------------------------------
# FILE LIMITS
# ----------------------------------------------------------------------------
MAX_FILE_SIZE=209715200
MAX_FILES_MERGE=30
FILE_TTL_SEC=3600
EXCEL_ROW_LIMIT=5000

# ----------------------------------------------------------------------------
# REDIS
# ----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=1000
RATE_LIMIT_WINDOW_SEC=60

# ----------------------------------------------------------------------------
# CELERY QUEUE LIMITS (Backpressure)
# ----------------------------------------------------------------------------
CELERY_FAST_QUEUE_MAX=500
CELERY_OFFICE_QUEUE_MAX=200
CELERY_SLOW_QUEUE_MAX=100

# ----------------------------------------------------------------------------
# EXTERNAL TOOLS
# ----------------------------------------------------------------------------
LIBREOFFICE_PATH=soffice
GHOSTSCRIPT_PATH=gs
TESSERACT_PATH=tesseract
WKHTMLTOPDF_PATH=wkhtmltopdf
VERAPDF_PATH=verapdf

# ----------------------------------------------------------------------------
# TIMEOUTS (seconds)
# ----------------------------------------------------------------------------
PDF2WORD_TIMEOUT=900
PDF2WORD_SYNC_LIMIT=20971520
PDFA_TIMEOUT=300
SUBPROCESS_TIMEOUT=300

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
ZIP_BOMB_RATIO=100
CORS_ORIGINS=*
SIGNED_URL_EXPIRY=3600

# ----------------------------------------------------------------------------
# CIRCUIT BREAKER
# ----------------------------------------------------------------------------
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=60

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
PDFA_VALIDATE=false

# ----------------------------------------------------------------------------
# STORAGE BACKEND (local or s3)
# ----------------------------------------------------------------------------
STORAGE_BACKEND=local
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

# ============================================================================
# V11.0.0 NEW CONFIGURATION (REQUIRED FOR LARGE FILE SUPPORT)
# ============================================================================

# ----------------------------------------------------------------------------
# JOB & CLEANUP
# ----------------------------------------------------------------------------
# Redis job TTL in seconds (default: 2 hours)
JOB_TTL_SEC=7200

# Maximum files to delete per cleanup pass (prevents I/O storms)
CLEANUP_MAX_DELETES=500

# ----------------------------------------------------------------------------
# CONVERSION LIMITS (Prevents OOM/DoS)
# ----------------------------------------------------------------------------
# Maximum slides for Word→PowerPoint conversion
MAX_SLIDES_PPT=200

# Maximum concurrent OCR threads (prevents resource exhaustion)
MAX_OCR_THREADS=2

# ----------------------------------------------------------------------------
# GRACEFUL SHUTDOWN
# ----------------------------------------------------------------------------
# Timeout for graceful shutdown (seconds)
SHUTDOWN_TIMEOUT=30

# ----------------------------------------------------------------------------
# GUNICORN WORKER CONFIGURATION
# ----------------------------------------------------------------------------
# Number of Gunicorn worker processes
GUNICORN_WORKERS=4

# Number of threads per worker
GUNICORN_THREADS=8

# ----------------------------------------------------------------------------
# CELERY TASK TIMEOUTS (V11.0.0)
# ----------------------------------------------------------------------------
# PDF to Word conversion timeout (30 minutes for large files)
CELERY_PDF_TO_WORD_TIMEOUT=1800
CELERY_PDF_TO_WORD_SOFT_TIMEOUT=1500

# OCR task timeout (60 minutes - OCR is CPU intensive)
CELERY_OCR_TIMEOUT=3600
CELERY_OCR_SOFT_TIMEOUT=3300

# Compress task timeout (10 minutes)
CELERY_COMPRESS_TIMEOUT=600

# ----------------------------------------------------------------------------
# LARGE FILE ASYNC THRESHOLD
# ----------------------------------------------------------------------------
# Files larger than this (bytes) use async Celery processing
# Default: 10MB = 10485760
ASYNC_FILE_THRESHOLD=10485760
