# PDFWala V13.0 — Environment Configuration
# ============================================================================

# --- REQUIRED ---
SECRET_KEY=generate-a-secure-random-key-here-min-32-chars
SIGNED_URL_SECRET=generate-another-secure-key-here
REDIS_URL=redis://redis:6379/0

# --- APPLICATION ---
FLASK_ENV=production
LOG_LEVEL=INFO
GUNICORN_WORKERS=4
GUNICORN_THREADS=8

# --- STORAGE ---
UPLOAD_FOLDER=/home/opc/pdfwala/uploads
OUTPUT_FOLDER=/home/opc/pdfwala/outputs
TEMP_FOLDER=/home/opc/pdfwala/temp

# --- LIMITS ---
MAX_FILE_SIZE=209715200
MAX_CONTENT_LENGTH=209715200
ASYNC_THRESHOLD=10485760
FILE_TTL_SEC=3600
EXCEL_ROW_LIMIT=5000
MAX_PDF_PAGES=500
MAX_IMAGE_PIXELS=200000000
MAX_IMAGE_DIMENSION=10000
MAX_WORD_PARAGRAPHS=2000
MAX_PPT_SLIDES=300

# --- REDIS ---
REDIS_JOB_TTL=7200
RATE_LIMIT_RPM=60

# --- EXTERNAL TOOLS ---
GHOSTSCRIPT=gs
LIBREOFFICE=soffice

# --- TIMEOUTS ---
SUBPROCESS_TIMEOUT=120
PDFA_TIMEOUT=180
OCR_TIMEOUT=300
TASK_SOFT_TIMEOUT=540
TASK_HARD_TIMEOUT=600

# --- SECURITY ---
CORS_ORIGINS=*
API_KEYS=
