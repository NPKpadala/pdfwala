# ============================================================================
# PDFWala V11.1.0 - Environment Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# SECURITY (REQUIRED - CHANGE THESE!)
# ----------------------------------------------------------------------------
SECRET_KEY=generate-a-secure-random-key-here-min-32-chars
SIGNED_URL_SECRET=generate-another-secure-key-here
API_KEY=pdfwala_your_admin_api_key_here

# ----------------------------------------------------------------------------
# APPLICATION
# ----------------------------------------------------------------------------
APP_PORT=5000
LOG_LEVEL=INFO
FLASK_DEBUG=false
VERSION=11.0.0

# ----------------------------------------------------------------------------
# STORAGE PATHS (Oracle VM)
# ----------------------------------------------------------------------------
BASE_DATA_DIR=/home/opc/pdfwala
UPLOAD_FOLDER=/home/opc/pdfwala/uploads
OUTPUT_FOLDER=/home/opc/pdfwala/outputs
TEMP_FOLDER=/home/opc/pdfwala/temp

# ----------------------------------------------------------------------------
# FILE LIMITS
# ----------------------------------------------------------------------------
MAX_FILE_SIZE=209715200
MAX_FILES_MERGE=30
FILE_TTL_SEC=3600
EXCEL_ROW_LIMIT=5000

# ----------------------------------------------------------------------------
# REDIS
# ----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=1000
RATE_LIMIT_WINDOW_SEC=60

# ----------------------------------------------------------------------------
# CELERY QUEUE LIMITS (Backpressure)
# ----------------------------------------------------------------------------
CELERY_FAST_QUEUE_MAX=500
CELERY_OFFICE_QUEUE_MAX=200
CELERY_SLOW_QUEUE_MAX=100

# ----------------------------------------------------------------------------
# EXTERNAL TOOLS
# ----------------------------------------------------------------------------
LIBREOFFICE_PATH=soffice
GHOSTSCRIPT_PATH=gs
TESSERACT_PATH=tesseract
WKHTMLTOPDF_PATH=wkhtmltopdf
VERAPDF_PATH=verapdf

# ----------------------------------------------------------------------------
# TIMEOUTS (seconds)
# ----------------------------------------------------------------------------
PDF2WORD_TIMEOUT=900
PDF2WORD_SYNC_LIMIT=20971520
PDFA_TIMEOUT=300
SUBPROCESS_TIMEOUT=300

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
ZIP_BOMB_RATIO=100
# Set to your actual domain in production. Empty = same-origin only.
CORS_ORIGINS=https://npkpadala.com
SIGNED_URL_EXPIRY=3600

# ----------------------------------------------------------------------------
# CIRCUIT BREAKER
# ----------------------------------------------------------------------------
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=60

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
PDFA_VALIDATE=false

# ----------------------------------------------------------------------------
# STORAGE BACKEND (local or s3)
# ----------------------------------------------------------------------------
STORAGE_BACKEND=local

# ============================================================================
# V11.1.0 — CHUNKED PARALLEL PROCESSING
# ============================================================================

# ----------------------------------------------------------------------------
# JOB & CLEANUP
# ----------------------------------------------------------------------------
JOB_TTL_SEC=7200
CLEANUP_MAX_DELETES=500

# ----------------------------------------------------------------------------
# CONVERSION LIMITS (Prevents OOM/DoS)
# ----------------------------------------------------------------------------
MAX_SLIDES_PPT=200
MAX_OCR_THREADS=2
MAX_COMPARE_PAGES=50
MAX_OCR_PAGES_SYNC=30
MAX_IMAGE_PAGES=2000

# ----------------------------------------------------------------------------
# CHUNKED OCR (Tesseract: ~200 MB RAM/worker)
# ----------------------------------------------------------------------------
OCR_CHUNK_THRESHOLD=50
OCR_CHUNK_PAGES=30
OCR_MAX_WORKERS=2

# ----------------------------------------------------------------------------
# CHUNKED PDF-TO-EXCEL (pdfplumber: moderate CPU+RAM)
# ----------------------------------------------------------------------------
PDF_TO_EXCEL_CHUNK_THRESHOLD=80
PDF_TO_EXCEL_CHUNK_PAGES=80
PDF_TO_EXCEL_MAX_WORKERS=2

# ----------------------------------------------------------------------------
# CHUNKED WATERMARK (light text/image stamp)
# ----------------------------------------------------------------------------
WATERMARK_CHUNK_THRESHOLD=200
WATERMARK_CHUNK_PAGES=100
WATERMARK_MAX_WORKERS=4
MAX_WATERMARK_PAGES=1000

# ----------------------------------------------------------------------------
# CHUNKED ROTATE (trivial PyMuPDF op)
# ----------------------------------------------------------------------------
ROTATE_CHUNK_THRESHOLD=200
ROTATE_CHUNK_PAGES=100
ROTATE_MAX_WORKERS=4
MAX_ROTATE_PAGES=1000

# ----------------------------------------------------------------------------
# CHUNKED PAGE NUMBERS (light overlay op)
# ----------------------------------------------------------------------------
PAGE_NUMBERS_CHUNK_THRESHOLD=200
PAGE_NUMBERS_CHUNK_PAGES=100
PAGE_NUMBERS_MAX_WORKERS=4
MAX_PAGE_NUMBERS_PAGES=1000

# ----------------------------------------------------------------------------
# CHUNKED REDACT (text search: moderate CPU)
# ----------------------------------------------------------------------------
REDACT_CHUNK_THRESHOLD=50
REDACT_CHUNK_PAGES=50
REDACT_MAX_WORKERS=2
MAX_REDACT_PAGES=500

# ----------------------------------------------------------------------------
# CHUNKED PDF-TO-IMAGE (rasterize: fast per-page)
# ----------------------------------------------------------------------------
PDF_TO_IMAGE_CHUNK_THRESHOLD=50
PDF_TO_IMAGE_CHUNK_PAGES=50
PDF_TO_IMAGE_MAX_WORKERS=4

# ----------------------------------------------------------------------------
# CHUNKED CROP (trivial cropbox set)
# ----------------------------------------------------------------------------
CROP_CHUNK_THRESHOLD=200
CROP_CHUNK_PAGES=100
CROP_MAX_WORKERS=4
MAX_CROP_PAGES=1000

# ----------------------------------------------------------------------------
# GRACEFUL SHUTDOWN
# ----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT=30

# ----------------------------------------------------------------------------
# GUNICORN WORKER CONFIGURATION
# ----------------------------------------------------------------------------
GUNICORN_WORKERS=4
GUNICORN_THREADS=8

# ----------------------------------------------------------------------------
# LARGE FILE ASYNC THRESHOLD
# ----------------------------------------------------------------------------
ASYNC_FILE_THRESHOLD=10485760
