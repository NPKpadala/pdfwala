# Telegram Bot Credentials (REPLACE WITH YOUR OWN)
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=123456789

# Thresholds
CPU_THRESHOLD=90
RAM_THRESHOLD=90
DISK_THRESHOLD=90
UPLOAD_SIZE_GB=10
SWAP_THRESHOLD=50
LOAD_MULTIPLIER=1.5

# Intervals (seconds)
CHECK_INTERVAL=60
